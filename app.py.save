import os
import requests
import pandas as pd
import streamlit as st
import plotly.express as px

st.set_page_config(page_title="Quant Terminal", layout="wide")st.title("Quant Terminal gratuit")

ALPHAVANTAGE_API_KEY = st.secrets.get("ALPHAVANTAGE_API_KEY", os.getenv("ALPHAVANTAGE_API_KEY", ""))
MARKETSTACK_API_KEY = st.secrets.get("MARKETSTACK_API_KEY", os.getenv("MARKETSTACK_API_KEY", ""))

ticker = st.sidebar.text_input("Ticker", "AAPL").upper().strip()
source = st.sidebar.selectbox("Source", ["Alpha Vantage", "Marketstack"])

@st.cache_data(ttl=900)
def alpha_data(sym):
    url = "https://www.alphavantage.co/query"
    params = {
        "function": "TIME_SERIES_DAILY_ADJUSTED",
        "symbol": sym,
        "outputsize": "compact",
        "apikey": ALPHAVANTAGE_API_KEY
    }
    r = requests.get(url, params=params, timeout=20).json()
    ts = r.get("Time Series (Daily)", {})
    if not ts:
        return pd.DataFrame(), {}
    df = pd.DataFrame(ts).T
    df.index = pd.to_datetime(df.index)
    df = df.sort_index()
    df = df.rename(columns={
        "1. open": "open",
        "2. high": "high",
        "3. low": "low",
        "4. close": "close",
        "6. volume": "volume"
    })
    for c in df.columns:
        df[c] = pd.to_numeric(df[c], errors="coerce")
    quote = requests.get(url, params={"function": "GLOBAL_QUOTE", "symbol": sym, "apikey": ALPHAVANTAGE_API_KEY}, timeout=20).json().get("Global Quote", {})
    return df, quote

@st.cache_data(ttl=900)
def marketstack_data(sym):
    url = "https://api.marketstack.com/v1/eod"
    params = {"access_key": MARKETSTACK_API_KEY, "symbols": sym, "limit": 100}
    r = requests.get(url, params=params, timeout=20).json()
    data = r.get("data", [])
    if not data:
        return pd.DataFrame()
    df = pd.DataFrame(data)
    df["date"] = pd.to_datetime(df["date"])
    df = df.sort_values("date")
    return df

def quant_score(df):
    if df.empty or len(df) < 50:
        return None
    close = df["close"]
    ma20 = close.rolling(20).mean().iloc[-1]
    ma50 = close.rolling(50).mean().iloc[-1]
    ret20 = close.pct_change(20).iloc[-1]
    vol20 = close.pct_change().rolling(20).std().iloc[-1] * (252 ** 0.5)
    score = 0
    score += 1 if close.iloc[-1] > ma20 else -1
    score += 1 if ma20 > ma50 else -1
    score += 1 if ret20 > 0 else -1
    score += 1 if vol20 < 0.30 else -1
    return score

if source == "Alpha Vantage":
    if not ALPHAVANTAGE_API_KEY:
        st.warning("Ajoute ta clé Alpha Vantage dans les secrets.")
    df, quote = alpha_data(ticker) if ALPHAVANTAGE_API_KEY else (pd.DataFrame(), {})
else:
    if not MARKETSTACK_API_KEY:
        st.warning("Ajoute ta clé Marketstack dans les secrets.")
    df = marketstack_data(ticker) if MARKETSTACK_API_KEY else pd.DataFrame()
    quote = {}
    if not df.empty and "close" not in df.columns and "adj_close" in df.columns:
        df["close"] = df["adj_close"]

col1, col2 = st.columns([2, 1])

with col1:
    if not df.empty:
        plot_df = df.reset_index().rename(columns={"index": "date"})
        xcol = "date" if "date" in plot_df.columns else plot_df.columns[0]
        fig = px.line(plot_df, x=xcol, y="close", title=f"{ticker} - Prix")
        st.plotly_chart(fig, use_container_width=True)
    else:
        st.info("Aucune donnée chargée.")

with col2:
    st.subheader("Résumé")
    if source == "Alpha Vantage" and quote:
        st.metric("Dernier prix", quote.get("05. price", "N/A"), quote.get("10. change percent", None))
    elif not df.empty:
        st.metric("Dernier prix", f"{df['close'].iloc[-1]:.2f}")
    q = quant_score(df)
    st.metric("Score quant", "N/A" if q is None else q)

st.divider()
st.subheader("Data alternative")
st.write([
    f"Google Trends sur {ticker}",
    f"News financières et sentiment",
    f"Filings et communiqués société",
    f"Macro FRED / BCE / inflation / taux",
    f"Traffic web / jobs / transport selon le secteur"
])

st.divider()
st.subheader("Watchlist")
watchlist = st.text_input("Tickers séparés par virgules", "AAPL,MSFT,NVDA,SPY")
st.write([x.strip().upper() for x in watchlist.split(",") if x.strip()])
